# ─────────────────────────────────────────────
# Health Assistant — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Options: ollama | gemini | openai | anthropic | lmstudio
LLM_PROVIDER=ollama

# ── Ollama (local) ────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=1024

# ── LM Studio (local, OpenAI-compatible) ──────
LMSTUDIO_HOST=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen2.5:32b

# ── Google Gemini ─────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic ─────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Telegram Bot ──────────────────────────────
# The token is stored ENCRYPTED in the credential store, NOT here.
# Run once before starting:
#   python scripts/setup_telegram.py
#
# Alternative (legacy / compatibility): you can define it here,
# but the credential store takes priority when configured.
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Logging & Debug ───────────────────────────
LOG_LEVEL=INFO
DEBUG_MODE=false

# ── Telemetry ─────────────────────────────────
AGNO_TELEMETRY=false

# ── Encryption key (credential store) ─────────
# Master key for encrypting per-user credentials (Tanita + Garmin) in SQLite.
#
# Generate once — copy the output and paste below:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# IMPORTANT: keep this key safe — losing it means losing access to stored credentials.
SECRET_KEY=your_fernet_key_here

# ── Per-user credentials ──────────────────────
#
# All credentials are stored ENCRYPTED in the SQLite database,
# never in this file. Setup scripts:
#
#   Telegram token (required, once):
#     python scripts/setup_telegram.py
#
#   Tanita MyFitness (optional):
#     python scripts/setup_credentials.py      → choose "tanita"
#
#   Garmin Connect (optional, OAuth via browser):
#     python scripts/garmin_browser_auth.py --user <user_id>
#     (opens a Chromium window — log in with your Garmin account)
#     Tokens valid ~6 months, stored in data/garmin_tokens/<user_id>/
#
# <user_id> = numeric Telegram ID (visible in your profile with /profile)
