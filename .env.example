# ─────────────────────────────────────────────
# Health Assistant — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Options: ollama | gemini | openai | anthropic | lmstudio
LLM_PROVIDER=ollama

# ── Ollama (local) ────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=1024

# ── LM Studio (local, OpenAI-compatible) ──────
LMSTUDIO_HOST=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen2.5:32b

# ── Google Gemini ─────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic ─────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Telegram Bot ──────────────────────────────
# O token é guardado ENCRIPTADO no credential store, NÃO aqui.
# Execute uma vez antes de iniciar:
#   python scripts/setup_telegram.py
#
# Alternativa (legado / compatibilidade): podes definir aqui,
# mas o credential store tem prioridade quando configurado.
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Logging & Debug ───────────────────────────
LOG_LEVEL=INFO
DEBUG_MODE=false

# ── Telemetry ─────────────────────────────────
AGNO_TELEMETRY=false

# ── Encryption key (credential store) ─────────
# Master key for encrypting per-user credentials (Tanita + Garmin) in SQLite.
#
# Generate once — copy the output and paste below:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# IMPORTANT: keep this key safe — losing it means losing access to stored credentials.
SECRET_KEY=your_fernet_key_here

# ── Credenciais por utilizador ────────────────
#
# Todas as credenciais são guardadas ENCRIPTADAS na base de dados SQLite,
# nunca neste ficheiro. Scripts de configuração:
#
#   Token Telegram (obrigatório, uma vez):
#     python scripts/setup_telegram.py
#
#   Tanita MyFitness (opcional):
#     python scripts/setup_credentials.py      → escolhe "tanita"
#
#   Garmin Connect (opcional, OAuth via browser):
#     python scripts/garmin_browser_auth.py --user <user_id>
#     (abre janela Chromium — faz login com a conta Garmin)
#     Tokens válidos ~6 meses, guardados em data/garmin_tokens/<user_id>/
#
# <user_id> = ID numérico do Telegram (visível no perfil com /profile)
